{
  "expo": {
    "name": "Compass",
    "slug": "compass",
    "scheme": "compass",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0e3320",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "app.compass.parent",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:compass.app",
        "applinks:*.compass.app"
      ]
    },
    "android": {
      "package": "app.compass.parent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e3320"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "compass.app" },
            { "scheme": "https", "host": "*.compass.app" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
