{
  "expo": {
    "name": "Compass",
    "slug": "compass",
    "scheme": "compass",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0e3320",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "app.compass.parent",
      "supportsTablet": false
    },
    "android": {
      "package": "app.compass.parent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e3320"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
