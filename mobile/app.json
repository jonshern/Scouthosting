{
  "expo": {
    "name": "Compass",
    "slug": "compass",
    "scheme": "compass",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0e3320",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "app.compass.parent",
      "supportsTablet": false
    },
    "android": {
      "package": "app.compass.parent",
      "adaptiveIcon": {
        "backgroundColor": "#0e3320"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
