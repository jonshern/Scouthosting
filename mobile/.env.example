# Mobile env. Copy to mobile/.env (gitignored) and edit. EXPO_PUBLIC_*
# vars are baked into the Metro bundle at build time, so changing them
# requires a Metro restart (`make mobile`).
#
# Daily-dev (server on the Mac):
#   EXPO_PUBLIC_COMPASS_BASE_URL=http://localhost:5050   # iOS simulator
#   EXPO_PUBLIC_COMPASS_APEX=localhost:5050
#
# For a real iPhone on the same Wi-Fi, swap localhost for the Mac's LAN IP:
#   EXPO_PUBLIC_COMPASS_BASE_URL=http://192.168.1.42:5050
#
# Staging (Fly.io):
#   EXPO_PUBLIC_COMPASS_BASE_URL=https://compass-staging.fly.dev
#   EXPO_PUBLIC_COMPASS_APEX=compass-staging.fly.dev
#
# Production (real custom domain): leave both unset; the bundle defaults
# to https://<orgSlug>.compass.app.

EXPO_PUBLIC_COMPASS_BASE_URL=
EXPO_PUBLIC_COMPASS_APEX=
