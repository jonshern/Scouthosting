// Scouthosting database schema.
//
// Single Postgres database, single schema. Tenant isolation is enforced at
// the application layer via the `orgId` column on every org-scoped table.
//
// Deferred (tracked as [security] items in ROADMAP.md):
//   - Postgres Row-Level Security policies on org-scoped tables
//   - Per-tenant encryption keys
//   - Field-level encryption for sensitive PII (medical, contact info)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Control plane
// ------------------------------------------------------------------

enum UnitType {
  Troop
  Pack
  Crew
  Ship
  Post
}

enum Plan {
  patrol
  troop
  council
}

enum Role {
  scout
  parent
  leader
  admin
}

model Org {
  id                  String   @id @default(cuid())
  slug                String   @unique
  unitType            UnitType
  unitNumber          String
  displayName         String
  tagline             String?
  charterOrg          String
  city                String
  state               String
  council             String?
  district            String?
  founded             String?
  meetingDay          String   @default("Mondays")
  meetingTime         String   @default("7:00 PM")
  meetingLocation     String?
  scoutmasterName     String
  scoutmasterEmail    String
  committeeChairEmail String?
  primaryColor        String   @default("#1d6b39")
  accentColor         String   @default("#caa54a")
  plan                Plan     @default(patrol)
  isDemo              Boolean  @default(false)
  customDomain        String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships OrgMembership[]
  members     Member[]
  events      Event[]
  photos      Photo[]
  albums      Album[]
  forms       Form[]
  page        Page?
  announcements Announcement[]

  @@index([plan])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  emailVerified Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions    Session[]
  memberships OrgMembership[]
  announcements Announcement[]
}

// A user can belong to many orgs (parent with kids in two units, leader
// who serves at council level, etc.). Each membership has a role within
// that org.
model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      Role     @default(parent)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ------------------------------------------------------------------
// Org-scoped data (every row carries orgId)
// ------------------------------------------------------------------

model Member {
  id             String   @id @default(cuid())
  orgId          String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  // Drives which channel a broadcast targets this member on.
  // email: send email only
  // sms:   send SMS only (requires phone + smsOptIn)
  // both:  send both
  // none:  do not contact (still appears in the directory)
  commPreference String   @default("email")
  smsOptIn       Boolean  @default(false)
  patrol         String?
  position       String?  // SPL, ASPL, Patrol Leader, Scoutmaster, etc.
  joinedAt       DateTime @default(now())
  birthdate      DateTime?
  isYouth        Boolean  @default(true)
  dietaryFlags   String[] @default([]) // e.g. ["vegetarian", "gluten-free"]
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, lastName])
}

model Event {
  id              String   @id @default(cuid())
  orgId           String
  title           String
  description     String?
  startsAt        DateTime
  endsAt          DateTime?
  allDay          Boolean  @default(false)
  location        String?
  // For map links: stored verbatim and used to build Google/Apple/Waze URLs
  // at render time.
  locationAddress String?
  cost            Int?     // dollars
  capacity        Int?
  signupRequired  Boolean  @default(false)
  category        String?  // meeting, campout, service, court-of-honor...
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, startsAt])
}

model Album {
  id          String    @id @default(cuid())
  orgId       String
  title       String
  slug        String
  description String?
  visibility  String    @default("public") // public | members
  takenAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org    Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([orgId, slug])
  @@index([orgId, takenAt])
}

model Photo {
  id           String    @id @default(cuid())
  orgId        String
  albumId      String
  filename     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  caption      String?
  takenAt      DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([orgId, albumId, sortOrder])
}

model Form {
  id        String   @id @default(cuid())
  orgId     String
  title     String
  url       String
  category  String?  // health, permission, bylaws, welcome, ...
  visibility String  @default("members") // public | members | leaders
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
}

// CMS: per-org editable home-page content. Single record per org for now;
// later we can add slug + relax @unique to support multiple custom pages.
model Page {
  id           String   @id @default(cuid())
  orgId        String   @unique
  heroHeadline String?
  heroLede     String?
  aboutBody    String?
  joinBody     String?
  contactNote  String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String    @id @default(cuid())
  orgId       String
  title       String
  body        String
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  pinned      Boolean   @default(false)
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org    Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([orgId, publishedAt])
  @@index([orgId, pinned, publishedAt])
}
