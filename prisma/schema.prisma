// Scouthosting database schema.
//
// Single Postgres database, single schema. Tenant isolation is enforced at
// the application layer via the `orgId` column on every org-scoped table.
//
// Deferred (tracked as [security] items in ROADMAP.md):
//   - Postgres Row-Level Security policies on org-scoped tables
//   - Per-tenant encryption keys
//   - Field-level encryption for sensitive PII (medical, contact info)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Control plane
// ------------------------------------------------------------------

enum UnitType {
  Troop
  Pack
  Crew
  Ship
  Post
}

enum Plan {
  patrol
  troop
  council
}

enum Role {
  scout
  parent
  leader
  admin
}

model Org {
  id                  String   @id @default(cuid())
  slug                String   @unique
  unitType            UnitType
  unitNumber          String
  displayName         String
  tagline             String?
  charterOrg          String
  city                String
  state               String
  council             String?
  district            String?
  founded             String?
  meetingDay          String   @default("Mondays")
  meetingTime         String   @default("7:00 PM")
  meetingLocation     String?
  scoutmasterName     String
  scoutmasterEmail    String
  committeeChairEmail String?
  primaryColor        String   @default("#1d6b39")
  accentColor         String   @default("#caa54a")
  // Per-org logo. Filename in the same per-org storage area as Photos
  // (lib/storage.js). null = use the default brand mark (unit number).
  logoFilename        String?
  plan                Plan     @default(patrol)
  isDemo              Boolean  @default(false)
  customDomain        String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships OrgMembership[]
  members     Member[]
  events      Event[]
  photos      Photo[]
  albums      Album[]
  forms       Form[]
  page        Page?
  announcements Announcement[]
  posts         Post[]
  comments      Comment[]
  rsvps         Rsvp[]
  slots         SignupSlot[]
  slotAssignments SlotAssignment[]
  tripPlans     TripPlan[]
  meals         Meal[]
  ingredients   Ingredient[]
  gear          GearItem[]
  equipment     Equipment[]
  customPages   CustomPage[]
  surveys       Survey[]
  eagleScouts   EagleScout[]
  eagleProjects EagleProject[]
  cohAwards     CohAward[]
  positionTerms PositionTerm[]
  equipmentLoans EquipmentLoan[]
  trainings     Training[]
  subgroups     Subgroup[]
  auditLogs     AuditLog[]
  carRides      CarRide[]
  carRideRiders CarRideRider[]
  meritBadgeCounselors MeritBadgeCounselor[]

  @@index([plan])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  emailVerified Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions    Session[]
  memberships OrgMembership[]
  announcements Announcement[]
  posts         Post[]
  comments      Comment[]
  oauthAccounts OAuthAccount[]
  rsvps         Rsvp[]
  slotAssignments SlotAssignment[]
}

// External identity provider linkage. One User can have multiple
// OAuthAccount rows (Google, Apple, Microsoft, …) but only one per
// (provider, providerAccountId). Email collisions across providers are
// resolved by the verified-email link at /auth/<provider>/callback.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String   // "google", "apple", ...
  providerAccountId String   // provider's stable user id (e.g. Google `sub`)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// A user can belong to many orgs (parent with kids in two units, leader
// who serves at council level, etc.). Each membership has a role within
// that org.
model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      Role     @default(parent)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ------------------------------------------------------------------
// Org-scoped data (every row carries orgId)
// ------------------------------------------------------------------

model Member {
  id             String   @id @default(cuid())
  orgId          String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  // Drives which channel a broadcast targets this member on.
  // email: send email only
  // sms:   send SMS only (requires phone + smsOptIn)
  // both:  send both
  // none:  do not contact (still appears in the directory)
  commPreference String   @default("email")
  smsOptIn       Boolean  @default(false)
  patrol         String?
  position       String?  // SPL, ASPL, Patrol Leader, Scoutmaster, etc.
  joinedAt       DateTime @default(now())
  birthdate      DateTime?
  isYouth        Boolean  @default(true)
  dietaryFlags   String[] @default([]) // e.g. ["vegetarian", "gluten-free"]
  notes          String?
  // Scoutbook link — Scoutbook user id lets admins jump from the
  // member directory to that Scout's Scoutbook record. We don't store
  // any advancement data; that lives in Scoutbook.
  scoutbookUserId String?
  // Family linkage. Each row points to its parent Members (typically the
  // youth's mom/dad/guardian); the inverse relation gives parents their
  // children. Postgres array of Member IDs keeps schema simple — no join
  // table needed for v1. Filter at query time.
  parentIds      String[] @default([])
  // Recipient-level unsubscribe. Set when the member clicks the
  // unsubscribe link in a broadcast (or hits the one-click List-Unsubscribe
  // header). Filters them out of audienceFor regardless of commPreference.
  emailUnsubscribed Boolean   @default(false)
  unsubscribedAt    DateTime?
  // Free-form roster lookups: "who has WFA?", "who can drive a 15-passenger
  // van?", "who plays a guitar for campfires?". Lowercased on save for
  // dedupe; display preserves first-seen casing.
  skills         String[] @default([])
  interests      String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rsvps Rsvp[]
  positionTerms PositionTerm[]
  equipmentLoans EquipmentLoan[]
  trainings     Training[]
  meritBadgeCounselors MeritBadgeCounselor[]

  @@index([orgId])
  @@index([orgId, lastName])
}

model Event {
  id              String   @id @default(cuid())
  orgId           String
  title           String
  description     String?
  startsAt        DateTime
  endsAt          DateTime?
  allDay          Boolean  @default(false)
  location        String?
  // For map links: stored verbatim and used to build Google/Apple/Waze URLs
  // at render time.
  locationAddress String?
  cost            Int?     // dollars
  capacity        Int?
  signupRequired  Boolean  @default(false)
  category        String?  // meeting, campout, service, court-of-honor...
  // RFC 5545 RRULE without the leading "RRULE:" prefix. Null = single
  // occurrence. Examples: "FREQ=WEEKLY;BYDAY=MO" (every Monday),
  // "FREQ=MONTHLY;BYDAY=1TU" (first Tuesday of every month).
  rrule           String?
  recurrenceUntil DateTime?
  // Per-attendee credits this event grants. A 2-night campout sets
  // campingNights = 2; a service project sets serviceHours = 4. Every
  // member with a "yes" RSVP earns the credits when /admin/credits
  // computes totals. null/0 means the event doesn't grant that credit.
  serviceHours    Float?
  campingNights   Int?
  hikingMiles     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rsvps     Rsvp[]
  slots     SignupSlot[]
  plan      TripPlan?
  cohAwards CohAward[]
  rides     CarRide[]

  @@index([orgId, startsAt])
}

// A sign-up "slot" is a discrete thing for an event that needs a person
// (or N people): drivers, food items to bring, gear to provide. Unlike
// RSVPs (one-per-person, yes/no/maybe), slots are tied to specific tasks.
model SignupSlot {
  id             String   @id @default(cuid())
  orgId          String
  eventId        String
  title          String          // "Bring drinks for 30", "Drive 2 scouts"
  description    String?
  capacity       Int      @default(1)
  // When a slot fills, additional sign-ups join a waitlist (ordered by
  // createdAt). The oldest waitlister auto-promotes when an active
  // assignment is released. Leaders can disable per-slot.
  allowWaitlist  Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org         Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments SlotAssignment[]

  @@index([orgId, eventId, sortOrder])
}

model SlotAssignment {
  id         String   @id @default(cuid())
  orgId      String
  slotId     String
  userId     String?  // signed-in user (preferred path)
  name       String
  email      String?
  notes      String?
  // True while the assignment is queued behind a full slot. When an
  // active assignment is released, the oldest waitlisted row is
  // promoted in the same transaction.
  waitlisted Boolean  @default(false)
  createdAt  DateTime @default(now())

  org  Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slot SignupSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Block dupes by signed-in user; (slot, email) handles the anon path.
  @@unique([slotId, userId])
  @@unique([slotId, email])
  @@index([orgId, slotId])
}

model Rsvp {
  id        String   @id @default(cuid())
  orgId     String
  eventId   String
  userId    String?  // signed-in user (preferred path)
  memberId  String?  // optional link to the directory entry
  name      String
  email     String?
  response  String   @default("yes") // yes | no | maybe
  guests    Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // Idempotent on (eventId, userId) when the user signed in, and on
  // (eventId, lower(email)) for anonymous email-link RSVPs.
  @@unique([eventId, userId])
  @@unique([eventId, email])
  @@index([orgId, eventId])
}

model Album {
  id          String    @id @default(cuid())
  orgId       String
  title       String
  slug        String
  description String?
  visibility  String    @default("public") // public | members
  takenAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org    Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([orgId, slug])
  @@index([orgId, takenAt])
}

model Photo {
  id           String    @id @default(cuid())
  orgId        String
  albumId      String
  filename     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  caption      String?
  takenAt      DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([orgId, albumId, sortOrder])
}

model Form {
  id           String   @id @default(cuid())
  orgId        String
  title        String
  // A form is either an uploaded file (filename) or an external link
  // (url). At least one is required; the admin UI enforces it.
  url          String?
  filename     String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  category     String?  // health, permission, bylaws, welcome, ...
  visibility   String   @default("members") // public | members | leaders
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
}

model MailLog {
  id              String   @id @default(cuid())
  orgId           String
  authorId        String?
  subject         String
  body            String
  channel         String   @default("email") // email | sms | both
  audienceLabel   String   // "Everyone", "Adults", "Youth", "Patrol: Eagles", ...
  recipientCount  Int      @default(0)
  status          String   @default("sent")  // sent | failed | partial | dryrun
  errors          String?
  sentAt          DateTime @default(now())

  // Recipient snapshot — JSON array of { name, email, phone, channel } so the
  // history shows who got the message even if directory entries change later.
  recipients      Json
}

// CMS: per-org editable home-page content. Single record per org for now;
// later we can add slug + relax @unique to support multiple custom pages.
model Page {
  id           String   @id @default(cuid())
  orgId        String   @unique
  heroHeadline String?
  heroLede     String?
  aboutBody    String?
  joinBody     String?
  contactNote  String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String    @id @default(cuid())
  orgId       String
  title       String
  body        String
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  pinned      Boolean   @default(false)
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org    Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([orgId, publishedAt])
  @@index([orgId, pinned, publishedAt])
}

// Activity feed: a generic timeline post that can carry text, attached
// photos, or a referenced album. Subsumes "announcements + albums" into
// a single chronological surface; existing Announcement/Album models are
// kept around so older tenant content keeps rendering.
model Post {
  id          String      @id @default(cuid())
  orgId       String
  authorId    String?
  title       String?
  body        String
  visibility  String      @default("public")  // public | members
  pinned      Boolean     @default(false)
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  org     Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author  User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  photos  PostPhoto[]
  comments Comment[]

  @@index([orgId, publishedAt])
  @@index([orgId, pinned, publishedAt])
}

model PostPhoto {
  id           String   @id @default(cuid())
  orgId        String
  postId       String
  filename     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  caption      String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([orgId, postId, sortOrder])
}

// Trip & meal planner. One plan per Event. Headcount can be overridden,
// otherwise derived from the count of yes-RSVPs at render time.
model TripPlan {
  id              String   @id @default(cuid())
  orgId           String
  eventId         String   @unique
  headcountOverride Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  meals Meal[]
  gear  GearItem[]

  @@index([orgId])
}

model Meal {
  id           String   @id @default(cuid())
  orgId        String
  tripPlanId   String
  name         String   // "Saturday breakfast"
  recipeName   String?  // "Foil packets", "Mac and cheese"
  notes        String?
  // "Contains" tags applied at the recipe level (e.g. "contains-meat",
  // "contains-gluten"). Cross-checked against each Member.dietaryFlags
  // to surface conflicts on the planner. See lib/dietary.js for the
  // canonical tag set and conflict map.
  dietaryTags  String[] @default([])
  sortOrder    Int      @default(0)
  servesAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tripPlan    TripPlan    @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  ingredients Ingredient[]

  @@index([orgId, tripPlanId, sortOrder])
}

model Ingredient {
  id                String   @id @default(cuid())
  orgId             String
  mealId            String
  name              String   // "Ground beef"
  quantityPerPerson Float    // e.g., 0.25
  unit              String   // "lb", "oz", "ea", "cup", ...
  category          String?  // "Meat", "Produce", "Dairy", "Pantry", "Drinks", "Other"
  // Optional cost per `unit` (e.g. $5 per lb). When set, the trip plan
  // sums quantityPerPerson * unitCost across meals to surface a
  // cost-per-Scout estimate.
  unitCost          Float?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([orgId, mealId])
}

// Gear / equipment checklist for a trip. Items can be assigned to a
// Member (the Quartermaster, a parent volunteer) or left unassigned.
model GearItem {
  id          String   @id @default(cuid())
  orgId       String
  tripPlanId  String
  name        String   // "Patrol box", "Propane stove"
  quantity    Int      @default(1)
  assignedTo  String?  // free-form name; future: link to Member
  notes       String?
  packed      Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tripPlan TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)

  @@index([orgId, tripPlanId, sortOrder])
}

// Comments on Posts. Members-only by definition (visibility lives on the
// parent Post; non-members can't even see the post). Authored by a User.
model Comment {
  id        String   @id @default(cuid())
  orgId     String
  postId    String
  authorId  String?
  body      String
  hidden    Boolean  @default(false)  // soft-moderation by admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([orgId, postId, createdAt])
}

// Permanent troop equipment catalog. Distinct from GearItem (which is
// a per-trip packing list). Tracks what the troop owns: patrol boxes,
// stoves, lanterns, propane tanks, the trailer itself, etc.
model Equipment {
  id          String   @id @default(cuid())
  orgId       String
  name        String           // "Patrol box #1", "Coleman 2-burner stove"
  category    String?          // "Patrol box", "Cooking", "Shelter", "Tools", ...
  serialOrTag String?          // serial number or asset tag
  location    String?          // "Trailer", "Storage closet", "Loaned: Smith family"
  condition   String   @default("good")  // good | fair | needs-repair | retired
  quantity    Int      @default(1)
  acquiredAt  DateTime?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  loans EquipmentLoan[]

  @@index([orgId, category])
  @@index([orgId, location])
}

// Equipment check-out trail. An open loan (returnedAt = null) means
// the item is currently out; closing it on return preserves the
// history for the Quartermaster's audit. Borrowers can either be
// linked Members (preferred) or free-form names — leaders sometimes
// loan gear to parents who aren't on the roster.
model EquipmentLoan {
  id            String    @id @default(cuid())
  orgId         String
  equipmentId   String
  memberId      String?
  borrowerName  String
  borrowerEmail String?
  checkedOutAt  DateTime  @default(now())
  dueAt         DateTime?
  returnedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org       Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  member    Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([orgId, equipmentId, checkedOutAt])
  @@index([orgId, returnedAt])
}

// Custom page — extra content pages beyond the home page (e.g. History,
// Bylaws summary, Eagle list, FAQ). Distinct from the Page model
// which holds editable home-page slots.
model CustomPage {
  id          String   @id @default(cuid())
  orgId       String
  slug        String   // URL slug, lowercased, kebab-case
  title       String
  body        String   // markdown-ish; rendered with paragraph + line-break preservation
  visibility  String   @default("public") // public | members
  sortOrder   Int      @default(0)
  showInNav   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, slug])
  @@index([orgId, sortOrder])
}

// Surveys: leader-composed question sets that members (or anyone, if
// the survey is set to allow it) can fill out. Questions stored as
// JSON so we can support text / select / scale / yes-no without a
// table per question type. Responses likewise — answers keyed by
// question id.
model Survey {
  id            String   @id @default(cuid())
  orgId         String
  slug          String
  title         String
  description   String?
  // Array of { id, type, label, options?, required } objects. Types:
  //   "text"   — short free-form
  //   "long"   — paragraph
  //   "yesno"  — boolean
  //   "select" — pick one of options[]
  //   "multi"  — pick any of options[]
  //   "scale"  — 1–5
  questions     Json     @default("[]")
  // who can respond:
  //   "anyone"  — anonymous form, name + email required
  //   "members" — sign-in required
  audience      String   @default("anyone")
  closesAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org       Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@unique([orgId, slug])
  @@index([orgId, createdAt])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  orgId       String
  surveyId    String
  userId      String?  // signed-in path
  name        String
  email       String?
  // Map of questionId → answer (string | boolean | number | string[])
  answers     Json
  createdAt   DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([orgId, surveyId])
}

// Eagle Scout — public list of the troop's Eagles. Distinct from
// EagleProject (the workflow). Just names + dates for the public page.
model EagleScout {
  id          String   @id @default(cuid())
  orgId       String
  firstName   String
  lastName    String
  // ECOH date — when they earned Eagle.
  earnedAt    DateTime
  projectName String?
  // Optional link to a Member record (if still on the roster).
  memberId    String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, earnedAt])
}

// Eagle project workflow — internal tracker for in-progress and
// completed Eagle projects. Lives in Scouthosting (we're the
// communication / planning layer); the workbook itself lives in
// Scoutbook (advancement system of record).
model EagleProject {
  id            String   @id @default(cuid())
  orgId         String
  scoutName     String   // typed; we don't enforce a Member link
  beneficiary   String?  // who the project serves
  mentorName    String?
  status        String   @default("idea")  // idea | proposal | approved | in-progress | complete
  workbookUrl   String?  // link to the BSA workbook (uploaded elsewhere)
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
}

// Court of Honor program — list of awards / recognitions for a CoH
// event. Each row prints as a line item on the printable program.
// Tied to an Event (typically with category = "Court of Honor").
model CohAward {
  id          String   @id @default(cuid())
  orgId       String
  eventId     String
  recipient   String   // "Demo Scout 2"
  award       String   // "Tenderfoot rank", "First Aid merit badge", "Mile-Swim award"
  category    String?  // "Rank", "Merit Badge", "Award", "Recognition"
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId, eventId, sortOrder])
}

// Position-of-Responsibility history. Each term is a (member, position,
// startedAt, endedAt) tuple — endedAt = null means "currently holding".
// Member.position keeps the current label denormalized for fast list
// rendering; on save the admin reconciles by closing the open term and
// opening a new one when the label changes.
model PositionTerm {
  id        String   @id @default(cuid())
  orgId     String
  memberId  String
  position  String   // "SPL", "Scoutmaster", "Patrol Leader — Eagles"
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([orgId, memberId, startedAt])
  @@index([orgId, endedAt])
}

// Adult-leader training history. BSA YPT (Youth Protection Training)
// expires every 2 years; other courses (IOLS, Wood Badge, Scoutmaster
// Specifics) typically don't. expiresAt = null means "doesn't expire";
// otherwise the org-wide /admin/training page surfaces an "expires
// soon" warning when the date is within 60 days.
model Training {
  id          String    @id @default(cuid())
  orgId       String
  memberId    String
  courseName  String    // "Youth Protection Training", "IOLS", "Wood Badge", ...
  completedAt DateTime
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org    Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([orgId, memberId, completedAt])
  @@index([orgId, expiresAt])
}

// Dynamic subgroup — a saved audience query the broadcast tool can
// target. v1 keeps the rule set narrow on purpose: AND across set
// filters, OR within an array. Members match if they pass every
// non-empty filter.
//
//   isYouth = true    → only youth
//   isYouth = false   → only adults
//   isYouth = null    → either (don't filter)
//   patrols = []      → don't filter on patrol
//   skills  = ["WFA"] → member.skills contains "WFA" (case-insensitive)
//   trainings = ["Youth Protection Training"] → member has a non-expired
//                       training row matching one of these course names
model Subgroup {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  isYouth     Boolean?
  patrols     String[] @default([])
  skills      String[] @default([])
  interests   String[] @default([])
  trainings   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

// Audit log — who edited what, when. v1 captures CMS / member writes;
// the security backlog escalates this to "every read/write to youth
// records" with cryptographic chaining for tamper-evidence.
//
// userId may be null for system actions (provisioning, automated
// reconcile). userDisplay snapshots the actor's display name at the
// time of the action so log lines stay readable after a leader
// rotates out of the org.
model AuditLog {
  id           String   @id @default(cuid())
  orgId        String
  userId       String?
  userDisplay  String?
  entityType   String   // "Page", "Announcement", "Post", "Member", ...
  entityId     String?
  action       String   // "create", "update", "delete"
  summary      String?  // short human-readable: "Edited About body"
  createdAt    DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, entityType, createdAt])
}

// Driver / carpool plan. Distinct from SignupSlot's generic
// "Drivers / carpool" template — that captures *who can drive*. CarRide
// captures *the actual ride*: vehicle, seats, departure plan, and the
// list of riders assigned to it. v1 is admin-managed (leaders build
// the plan manually based on RSVPs).
model CarRide {
  id                  String          @id @default(cuid())
  orgId               String
  eventId             String
  driverName          String
  driverEmail         String?
  driverPhone         String?
  vehicleNote         String?         // "Honda Pilot — silver", "15-passenger van"
  seats               Int             @default(4)
  departureTime       DateTime?
  departureLocation   String?
  returnTime          DateTime?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  org    Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  event  Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  riders CarRideRider[]

  @@index([orgId, eventId])
}

model CarRideRider {
  id        String   @id @default(cuid())
  orgId     String
  rideId    String
  memberId  String?
  name      String
  email     String?
  isYouth   Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  org  Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ride CarRide @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([orgId, rideId])
}

// Troop's preferred Merit Badge Counselor list. Local-only, troop-curated;
// distinct from Scoutbook's national MBC directory. v1 captures who the
// troop actually uses for which badges. Scouts and parents read this list
// when they're picking a counselor.
model MeritBadgeCounselor {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  email       String?
  phone       String?
  badges      String[] @default([])  // e.g. ["First Aid", "Camping", "Citizenship in the Community"]
  // Optional link to a roster member if the counselor is also part of
  // the unit. Free-form names are allowed too — many councils share
  // counselors across units.
  memberId    String?
  notes       String?  // "Best for First Aid; reach out via email", "Lives in Oakdale"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([orgId, name])
  @@index([orgId, memberId])
}
