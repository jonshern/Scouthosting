# Copy to .env and fill in. Never commit .env.

# Postgres connection used by Prisma at runtime and by `prisma migrate`.
# Matches the docker-compose.yml defaults.
DATABASE_URL="postgresql://scouthosting:scouthosting@localhost:5432/scouthosting?schema=public"

# Express port
PORT=3000

# Set to "production" in deployed environments. Affects template caching
# and cookie security.
NODE_ENV=development

# Apex domain. Subdomains of this become tenant sites.
# In dev we additionally treat *.localhost as tenants.
APEX_DOMAIN=scouthosting.com

# Secret used to sign one-click RSVP tokens included in email reminders.
# Generate a strong random value in production (e.g. `openssl rand -hex 32`).
# RSVP_SECRET=

# Mail provider. "console" logs to stdout (dev). Production options:
#   "resend" — set RESEND_API_KEY (free 3k/mo at resend.com)
#   "smtp"   — set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
# MAIL_DRIVER=console
# MAIL_FROM="Scouthosting <noreply@scouthosting.com>"

# Resend (https://resend.com/api-keys)
# RESEND_API_KEY=re_...

# SMTP (any provider — Postmark, Mailgun, SES SMTP, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465, false for STARTTLS on 587
# SMTP_USER=apikey
# SMTP_PASS=...

# Cookie domain. Set to ".scouthosting.com" in production so a session cookie
# set on the apex (e.g. after Google OAuth callback) is valid on every org
# subdomain. Leave empty in dev unless you've configured *.localhost cookies.
# COOKIE_DOMAIN=

# Google OAuth — leave blank to disable the "Sign in with Google" button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be exactly:
#   https://<APEX_DOMAIN>/auth/google/callback
# In dev:
#   http://localhost:3000/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
