# Copy to .env and fill in. Never commit .env.

# Postgres connection used by Prisma at runtime and by `prisma migrate`.
# Matches the docker-compose.yml defaults.
DATABASE_URL="postgresql://compass:compass@localhost:5432/compass?schema=public"

# Express port
PORT=3000

# Set to "production" in deployed environments. Affects template caching
# and cookie security.
NODE_ENV=development

# Apex domain. Subdomains of this become tenant sites.
# In dev we additionally treat *.localhost as tenants.
APEX_DOMAIN=compass.app

# Secret used to sign one-click RSVP tokens included in email reminders.
# Generate a strong random value in production (e.g. `openssl rand -hex 32`).
# RSVP_SECRET=

# Mail provider. "console" logs to stdout (dev). Production options:
#   "resend" — set RESEND_API_KEY (free 3k/mo at resend.com)
#   "smtp"   — set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
# MAIL_DRIVER=console
# MAIL_FROM="Compass <noreply@compass.app>"

# Resend (https://resend.com/api-keys)
# RESEND_API_KEY=re_...
# Resend webhook secret. When configured, Resend POSTs delivery events
# (bounce / complaint) to https://<APEX_DOMAIN>/api/webhooks/resend; we
# verify the Svix-style signature and auto-mark Member.bouncedAt +
# emailUnsubscribed for hard bounces and complaints. Get the secret in
# the Resend dashboard → Webhooks → Add endpoint → copy "Signing secret".
# RESEND_WEBHOOK_SECRET=whsec_...

# SMTP (any provider — Postmark, Mailgun, SES SMTP, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465, false for STARTTLS on 587
# SMTP_USER=apikey
# SMTP_PASS=...

# SMS provider. "console" logs to stdout (dev). "twilio" hits the Twilio
# REST API. SMS broadcasts respect Member.commPreference + smsOptIn.
# SMS_DRIVER=console
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+15551234567

# Cookie domain. Set to ".compass.app" in production so the session
# cookie set on the apex (e.g. after Google OAuth) is also valid on
# every org subdomain. Leave empty in dev — Chromium rejects
# `Domain=.localhost`, and the apex → org subdomain transition uses a
# one-shot signed token (/auth/handoff) instead of relying on the
# shared cookie.
# COOKIE_DOMAIN=.compass.app

# Google OAuth — leave blank to disable the "Sign in with Google" button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be exactly:
#   https://<APEX_DOMAIN>/auth/google/callback
# In dev:
#   http://localhost:3000/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Apple Sign in — leave blank to disable the button.
# Set up a Services ID + Sign-in-with-Apple key in your Apple Developer
# account (https://developer.apple.com/account/resources/identifiers).
# Configured redirect URI must be exactly:
#   https://<APEX_DOMAIN>/auth/apple/callback
# Apple posts the callback (response_mode=form_post) when name + email
# scopes are requested, which is the default in our flow.
# APPLE_CLIENT_ID=com.compass.web        # Services ID (NOT the App ID)
# APPLE_TEAM_ID=ABCDE12345
# APPLE_KEY_ID=ABCDE12345
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
# APPLE_REDIRECT_URI=https://compass.app/auth/apple/callback

# Invitation token signing secret. If unset, falls through to
# AUTH_TOKEN_SECRET / RSVP_SECRET / SESSION_SECRET. Use a fresh
# 32-byte secret in production.
# INVITE_SECRET=

# Push notifications (mobile app). The default driver writes to logs;
# set EXPO_ACCESS_TOKEN to dispatch via Expo's push API (works for
# both iOS + Android via the Expo binary).
# PUSH_DRIVER=expo
# EXPO_ACCESS_TOKEN=
