{
  "name": "scouthosting",
  "version": "0.2.0",
  "private": true,
  "description": "The planning and communication hub for Scout units. Multi-tenant website platform with calendar, photos, group email, trip & meal planning, and a CMS. Defers advancement to Scoutbook.",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "provision": "node server/provision.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@node-rs/argon2": "^1.8.3",
    "@prisma/client": "^5.22.0",
    "arctic": "^1.9.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucia": "^3.2.2",
    "multer": "^2.0.0",
    "oslo": "^1.2.1",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "optionalDependencies": {
    "@google-cloud/storage": "^7.13.0",
    "nodemailer": "^6.9.16"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
